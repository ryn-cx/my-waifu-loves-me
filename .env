# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and acquire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="My Waifu Loves Me"
STACK_NAME=my-waifu-loves-me

# Backend
BACKEND_CORS_ORIGINS="https://mywaifuloves.me,http://mywaifuloves.me,https://mywaifulovesme.com,http://mywaifulovesme.com,http://localhost,http://localhost:5175,https://localhost,https://localhost:5175,http://localhost.tiangolo.com"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# Ports for local development
PROJECT_NUMBER=3

PROXY_HTTP_PORT=83
PROXY_DASHBOARD_PORT=8093
DB_PORT=5435
ADMINER_PORT=8083
BACKEND_PORT=8003
BACKEND_TEST_PORT=8103
MAILCATCHER_WEB_PORT=1083
MAILCATCHER_SMTP_PORT=1028
FRONTEND_PORT=5176
FRONTEND_TEST_PORT=5276
PLAYWRIGHT_PORT=9326
VITE_API_URL=http://localhost:8103
MAILCATCHER_HOST=http://localhost:1083
FRONTEND_TEST_URL=http://localhost:5276
